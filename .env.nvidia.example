# NVIDIA NIM / Integrate API (OpenAI-compatible)
# Copy to .env and fill NVIDIA_API_KEY.

LLM_PROVIDER=nvidia
PROVIDER_PROFILES_PATH=config/provider_profiles.json

# Provider profile defaults will auto-fill these, but you can pin explicitly.
NVIDIA_MODEL=minimaxai/minimax-m2.7
LLM_MODEL=minimaxai/minimax-m2.7
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_API_KEY_ENV=NVIDIA_API_KEY
NVIDIA_API_KEY=

# Runtime defaults
BASE_CONFIG_FILE=config/config.json
MEMORY_DUMP_FILE=
MEMORY_DUMP_FOLDER=data
SNAPSHOT_MANIFEST_FILE=results/snapshot_manifest.json
