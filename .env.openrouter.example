# OpenRouter (OpenAI-compatible)
# Copy to .env and fill OPENROUTER_API_KEY.

LLM_PROVIDER=openrouter
PROVIDER_PROFILES_PATH=config/provider_profiles.json

# Provider profile defaults will auto-fill these, but you can pin explicitly.
LLM_MODEL=qwen/qwen3.6-plus:free
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY_ENV=OPENROUTER_API_KEY
OPENROUTER_API_KEY=

# Runtime defaults
BASE_CONFIG_FILE=config/config.json
MEMORY_DUMP_FILE=
MEMORY_DUMP_FOLDER=data
SNAPSHOT_MANIFEST_FILE=results/snapshot_manifest.json
