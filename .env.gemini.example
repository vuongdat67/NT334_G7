# Gemini via OpenAI-compatible endpoint
# Copy to .env and fill GEMINI_API_KEY.

LLM_PROVIDER=gemini
PROVIDER_PROFILES_PATH=config/provider_profiles.json

# Provider profile defaults will auto-fill these, but you can pin explicitly.
LLM_MODEL=gemini-2.0-flash
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_API_KEY_ENV=GEMINI_API_KEY
GEMINI_API_KEY=

# Runtime defaults
BASE_CONFIG_FILE=config/config.json
MEMORY_DUMP_FILE=
MEMORY_DUMP_FOLDER=data
SNAPSHOT_MANIFEST_FILE=results/snapshot_manifest.json
