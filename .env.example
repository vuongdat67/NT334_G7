# Copy this file to .env and fill values
# For faster setup, you can also start from:
# - .env.gemini.example
# - .env.openrouter.example
# - .env.claude.example
# - .env.nvidia.example

# Required runtime defaults (used by config/config.json)
LLM_PROVIDER=
LLM_MODEL=
LLM_BASE_URL=
LLM_API_KEY_ENV=
MEMORY_DUMP_FILE=
MEMORY_DUMP_FOLDER=data
PROVIDER_PROFILES_PATH=config/provider_profiles.json

# Provider-specific API keys
LOCAL_LLM_API_KEY=local-not-needed
OPENROUTER_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
NVIDIA_API_KEY=

# Provider-specific model defaults (optional)
OPENROUTER_MODEL=
OPENAI_MODEL=
GEMINI_MODEL=gemini-2.0-flash
NVIDIA_MODEL=minimaxai/minimax-m2.7
CLAUDE_MODEL=anthropic/claude-3.7-sonnet
LMSTUDIO_MODEL=
OLLAMA_MODEL=

# Canonical file defaults
BASE_CONFIG_FILE=config/config.json
MODEL_PROFILES_FILE=config/model_profiles.json
SNAPSHOT_MANIFEST_FILE=results/snapshot_manifest.json
SNAPSHOT_CATEGORY=all
SNAPSHOT_LIMIT=0
RESULTS_ROOT=results/experiments
EXPERIMENT_NAME=default
SKIP_MODEL_ON_ERROR=true

# Optional fallback: if MODEL_PROFILES_FILE is missing, use comma-separated models.
# MODEL_LIST=qwen/qwen3.6-plus:free,nvidia/nemotron-nano-12b-v2-vl:free

# Optional
BATCH_OUTPUT_DIR=results/batch
