# Copy this file to .env and fill values

# Local model (LM Studio / Ollama OpenAI-compatible endpoint)
# For local endpoints that do not require auth, keep LOCAL_LLM_API_KEY as any non-empty string.
LOCAL_LLM_API_KEY=local-not-needed

# OpenAI cloud (optional)
OPENAI_API_KEY=

# OpenRouter (optional)
OPENROUTER_API_KEY=

# Optional generic override
OPENAI_BASE_URL=
