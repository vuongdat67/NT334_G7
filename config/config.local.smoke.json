{
  "volatility_script_path": "~/tools/volatility3/vol.py",
  "memory_dump_path": "./data/Snapshot_benign_1.elf",
  "volatility_plugins": [
    "windows.pslist"
  ],
  "prompt_template_path": "config/prompt_template_v1.txt",
  "decision_rules_path": "config/decision_rules.json",
  "llm_model": "llama-2-7b-chat",
  "llm_api_key_env": "LOCAL_LLM_API_KEY",
  "llm_base_url": "http://192.168.64.1:1234/v1",
  "llm_timeout_seconds": 180,
  "llm_max_output_tokens": 700,
  "llm_force_json_response_format": true,
  "llm_reasoning_enabled": false,
  "artifact_max_rows_per_plugin": {
    "default": 30,
    "windows.pslist": 30,
    "windows.vadinfo": 20,
    "windows.malfind": 15
  },
  "artifact_max_json_chars": 3000,
  "post_filter_enabled": true,
  "post_filter_min_conf_keep_for_allowlisted": 0.92,
  "temperature": 0,
  "majority_runs": 1,
  "output_report_path": "results/triage_report.smoke.json",
  "output_votes_path": "results/triage_votes.smoke.json"
}
